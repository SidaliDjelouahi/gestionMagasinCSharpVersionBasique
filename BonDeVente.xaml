<Page x:Class="MonAppGestion.BonDeVente"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BonDeVente"
    Background="White"
    Loaded="Page_Loaded"
    FocusManager.FocusedElement="{Binding ElementName=cbProducts}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0" Margin="0,0,10,0">
            <Grid.RowDefinitions>
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0">
                <TextBlock Text="Créer Bon de Vente" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="N° Vente:" Width="70" VerticalAlignment="Center"/>
                    <TextBox x:Name="txtNumVente" Width="200" />
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <TextBlock Text="Date:" Width="70" VerticalAlignment="Center"/>
                    <DatePicker x:Name="dpDateVente" Width="200" />
                </StackPanel>

                <Separator Margin="0,8" />

                <TextBlock Text="Ajouter ligne" FontWeight="Bold" Margin="0,6" />
                <StackPanel Orientation="Horizontal" Margin="0,4">
                    <StackPanel VerticalAlignment="Top">
                        <TextBox x:Name="txtProductSearch" Width="180" Height="24" KeyUp="txtProductSearch_KeyUp" KeyDown="txtProductSearch_KeyDown" MouseEnter="txtProductSearch_MouseEnter" />
                        <ListBox x:Name="lbProductSuggestions" Width="180" Height="120" Visibility="Collapsed"
                                 DisplayMemberPath="Nom" SelectionChanged="lbProductSuggestions_SelectionChanged" KeyDown="lbProductSuggestions_KeyDown"/>
                    </StackPanel>
                    <TextBox x:Name="txtQteLine" Width=" 40" Height="24" Margin="8,0" VerticalAlignment="Top" />
                    <TextBox x:Name="txtPrixLine" Width="60" Height="24" Margin="8,0" VerticalAlignment="Top" />
                    <Button x:Name="btnAddLine" Content="Ajouter" Width="80" Height="24" Click="btnAddLine_Click" Margin="8,0" VerticalAlignment="Top" />
                </StackPanel>
            </StackPanel>

            <StackPanel Orientation="Horizontal" Grid.Row="1" VerticalAlignment="Bottom" Margin="0,12,0,0">
                <TextBox x:Name="txtTotal" Width="250" Height="64" FontSize="50" IsEnabled="False" TextAlignment="Right" VerticalContentAlignment="Center" />
                <Button x:Name="btnSaveVente" Content="Enregistrerle bon" Click="btnSaveVente_Click" Margin="12,0,0,0" Width="150" Background="#007ACC" Foreground="White" />
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Lignes du bon" FontSize="20" FontWeight="Bold" />
            <DataGrid x:Name="dgDetails" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,8,0,0"
                      CellEditEnding="dgDetails_CellEditEnding" RowEditEnding="dgDetails_RowEditEnding">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Produit" Binding="{Binding Nom}" Width="*" />
                    <DataGridTextColumn Header="Prix" Binding="{Binding PrixVente}" Width="100" />
                    <DataGridTextColumn Header="Qte" Binding="{Binding Qte}" Width="80" />
                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="100" />
                    <DataGridTemplateColumn Header="Actions" Width="150">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Modifier" Click="Action_Edit_Click" Margin="4,0" />
                                    <Button Content="Supprimer" Click="Action_Delete_Click" Margin="4,0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </Grid>
</Page>
