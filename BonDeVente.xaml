<Page x:Class="MonAppGestion.BonDeVente"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="BonDeVente"
    Background="White"
    Loaded="Page_Loaded"
    FocusManager.FocusedElement="{Binding ElementName=cbProducts}">
    <Grid Margin="12">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="2*" />
            <ColumnDefinition Width="3*" />
        </Grid.ColumnDefinitions>

        <StackPanel Grid.Column="0" Margin="0,0,10,0">
            <TextBlock Text="Créer Bon de Vente" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />

            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="N° Vente:" Width="70" VerticalAlignment="Center"/>
                <TextBox x:Name="txtNumVente" Width="200" />
            </StackPanel>

            <StackPanel Orientation="Horizontal" Margin="0,4">
                <TextBlock Text="Date:" Width="70" VerticalAlignment="Center"/>
                <DatePicker x:Name="dpDateVente" Width="200" />
            </StackPanel>

            <Separator Margin="0,8" />

            <TextBlock Text="Ajouter ligne" FontWeight="Bold" Margin="0,6" />
            <StackPanel Orientation="Horizontal" Margin="0,4">
                <ComboBox x:Name="cbProducts" Width="200" DisplayMemberPath="Nom" SelectedValuePath="Id"
                          IsEditable="True" IsTextSearchEnabled="False" StaysOpenOnEdit="True" KeyUp="cbProducts_KeyUp" />
                <TextBox x:Name="txtQteLine" Width="60" Margin="8,0" />
                <TextBox x:Name="txtPrixLine" Width="80" Margin="8,0" />
                <Button x:Name="btnAddLine" Content="Ajouter" Click="btnAddLine_Click" Margin="8,0" />
            </StackPanel>

            <Button x:Name="btnSaveVente" Content="Enregistrer le bon" Click="btnSaveVente_Click" Margin="0,12,0,0" Width="200" Background="#007ACC" Foreground="White"/>
        </StackPanel>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
            </Grid.RowDefinitions>

            <TextBlock Text="Lignes du bon" FontSize="20" FontWeight="Bold" />
            <DataGrid x:Name="dgDetails" Grid.Row="1" AutoGenerateColumns="False" CanUserAddRows="False" Margin="0,8,0,0">
                <DataGrid.Columns>
                    <DataGridTextColumn Header="Produit" Binding="{Binding Nom}" Width="*" />
                    <DataGridTextColumn Header="Prix" Binding="{Binding PrixVente}" Width="100" />
                    <DataGridTextColumn Header="Qte" Binding="{Binding Qte}" Width="80" />
                    <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="100" />
                </DataGrid.Columns>
            </DataGrid>
        </Grid>

    </Grid>
</Page>
