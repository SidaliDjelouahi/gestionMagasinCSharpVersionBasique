<Page x:Class="MonAppGestion.Fournisseurs"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Fournisseurs"
      Background="White"
      Loaded="Page_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Gestion des Fournisseurs" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock>Nom</TextBlock>
                <TextBox x:Name="txtNom" Width="150" />
            </StackPanel>
            <StackPanel Margin="8,0,0,0">
                <TextBlock>Adresse</TextBlock>
                <TextBox x:Name="txtAdresse" Width="200" />
            </StackPanel>
            <StackPanel Margin="8,0,0,0">
                <TextBlock>Téléphone</TextBlock>
                <TextBox x:Name="txtTelephone" Width="150" />
            </StackPanel>

            <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" Margin="12,0,0,0">
                <Button x:Name="btnAjouter" Content="Ajouter" Click="btnAjouter_Click" Width="70" Margin="0,0,8,0" Background="Green" Foreground="White" />
                <Button x:Name="btnModifier" Content="Modifier" Click="btnModifier_Click" Width="70" Margin="0,0,8,0" Background="#007ACC" Foreground="White" IsEnabled="False" />
                <Button x:Name="btnSupprimer" Content="Supprimer" Click="btnSupprimer_Click" Width="70" Background="Red" Foreground="White" IsEnabled="False" />
                <Button x:Name="btnSituation" Content="Situation" Click="btnSituation_Click" Width="70" Margin="8,0,0,0" IsEnabled="False" />
            </StackPanel> 
        </StackPanel>

        <DataGrid x:Name="dgFournisseurs" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True" SelectionChanged="dgFournisseurs_SelectionChanged">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="60" />
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*" />
                <DataGridTextColumn Header="Adresse" Binding="{Binding Adresse}" Width="2*" />
                <DataGridTextColumn Header="Téléphone" Binding="{Binding Telephone}" Width="150" />
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="" x:Name="txtStatus" Foreground="Gray" Margin="0,8,0,0" />
    </Grid>
</Page>
