<Window x:Class="MonAppGestion.Dashboard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Tableau de Bord" Height="500" Width="900" WindowStartupLocation="CenterScreen"
    WindowState="Maximized">
    <DockPanel>
        <!-- Menu latéral -->
        <StackPanel DockPanel.Dock="Left" Width="150" Background="#F3F3F3">
            <TextBlock Text="Menu" FontSize="18" FontWeight="Bold" Margin="0,0,0,10"/>
            <Button x:Name="btnUtilisateurs" Content="Utilisateurs" Margin="0,5" Click="btnUtilisateurs_Click"/>
            <Button x:Name="btnProduits" Content="Produits" Margin="0,5" Click="btnProduits_Click"/>
            <Button x:Name="btnClients" Content="Clients" Margin="0,5" Click="btnClients_Click"/>
            <Button x:Name="btnBonAchat" Content="Bon d'achat" Margin="0,5" Click="btnBonAchat_Click"/>
            <Button x:Name="btnAchats" Content="Achats" Margin="0,5" Click="btnAchats_Click"/>
            <Button x:Name="btnAnalyse" Content="Analyse" Margin="0,5" Click="btnAnalyse_Click"/>
            <Button x:Name="btnSauvegardeDB" Content="Sauvegarde DB" Margin="0,5" Click="btnSauvegardeDB_Click"/>
            <Button x:Name="btnFournisseurs" Content="Fournisseurs" Margin="0,5" Click="btnFournisseurs_Click"/>
            <Button x:Name="btnVentes" Content="Ventes" Margin="0,5" Click="btnVentes_Click"/>
            <Button x:Name="btnBonDeVente" Content="Bon de vente" Margin="0,5" Click="btnBonDeVente_Click"/>
            <Button x:Name="btnAutre" Content="Autre page" Margin="0,5" Click="btnAutre_Click"/>
            <Separator Margin="0,10"/>
            <Button Content="Déconnexion" Margin="0,5" Click="btnLogout_Click"/>
        </StackPanel>

        <!-- Zone de contenu navigable -->
        <Frame x:Name="MainFrame" NavigationUIVisibility="Hidden"/>
    </DockPanel>
</Window>