<Page x:Class="MonAppGestion.Utilisateurs"
            xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
            xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
            Title="Utilisateurs"
            Background="White">
        <Grid Margin="20">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <TextBlock Text="Administration des Comptes" FontSize="22" FontWeight="Bold" Margin="0,0,0,15" Foreground="#007ACC"/>

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,20">
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Utilisateur:"/>
                <TextBox x:Name="txtNewUser" Width="150"/>
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Mot de passe:"/>
                <TextBox x:Name="txtNewPass" Width="150"/>
            </StackPanel>
            <StackPanel Margin="0,0,10,0">
                <TextBlock Text="Rôle:"/>
                <ComboBox x:Name="cbRank" Width="150">
                    <ComboBoxItem Content="developpeur" />
                    <ComboBoxItem Content="admin" />
                    <ComboBoxItem Content="assistant" />
                    <ComboBoxItem Content="user" />
                </ComboBox>
            </StackPanel>
            <Button x:Name="btnAjouter" Content="Ajouter" Click="btnAjouter_Click" Width="100" Height="30" VerticalAlignment="Bottom" Background="Green" Foreground="White"/>
        </StackPanel>

        <DataGrid x:Name="dgUsers" Grid.Row="2" AutoGenerateColumns="True" IsReadOnly="True" />

        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,10,0,0">
            <Button x:Name="btnSupprimer" Content="Supprimer" Click="btnSupprimer_Click" 
                Width="150" Height="30" Margin="0,0,8,0" Background="Red" Foreground="White"/>
            <Button x:Name="btnModifier" Content="Modifier" Click="btnModifier_Click"
                Width="150" Height="30" Background="#007ACC" Foreground="White"/>
        </StackPanel>
    </Grid>
    </Page>