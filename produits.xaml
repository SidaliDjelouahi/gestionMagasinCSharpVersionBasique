<Page x:Class="MonAppGestion.Produits"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Produits"
      Background="White">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Gestion des Produits" FontSize="20" FontWeight="Bold" Margin="0,0,0,10" />

        <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,0,0,10" HorizontalAlignment="Left">
            <StackPanel>
                <TextBlock>Code</TextBlock>
                <TextBox x:Name="txtCode" Width="120" />
            </StackPanel>
            <StackPanel>
                <TextBlock>Nom</TextBlock>
                <TextBox x:Name="txtNom" Width="180" />
            </StackPanel>
            <StackPanel>
                <TextBlock>Quantité</TextBlock>
                <TextBox x:Name="txtQte" Width="80" />
            </StackPanel>
            <StackPanel>
                <TextBlock>Prix achat</TextBlock>
                <TextBox x:Name="txtPrixAchat" Width="100" />
            </StackPanel>
            <StackPanel>
                <TextBlock>Prix vente</TextBlock>
                <TextBox x:Name="txtPrixVente" Width="100" />
            </StackPanel>
            <StackPanel>
                <TextBlock>Date exp.</TextBlock>
                <DatePicker x:Name="dpDateExp" Width="140" />
            </StackPanel>
            <StackPanel VerticalAlignment="Bottom" Orientation="Horizontal" Margin="10,0,0,0">
                <Button Content="Ajouter" Click="btnAjouter_Click" Width="100" Margin="0,0,8,0" Background="Green" Foreground="White" />
                <Button Content="Supprimer" Click="btnSupprimer_Click" Width="100" Background="Red" Foreground="White" />
            </StackPanel>
        </StackPanel>

        <DataGrid x:Name="dgProduits" Grid.Row="2" AutoGenerateColumns="False" IsReadOnly="True">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Id" Binding="{Binding Id}" Width="50"/>
                <DataGridTextColumn Header="Code" Binding="{Binding Code}" Width="100"/>
                <DataGridTextColumn Header="Nom" Binding="{Binding Nom}" Width="*"/>
                <DataGridTextColumn Header="Qte" Binding="{Binding Qte}" Width="80"/>
                <DataGridTextColumn Header="Prix Achat" Binding="{Binding PrixAchat}" Width="100"/>
                <DataGridTextColumn Header="Prix Vente" Binding="{Binding PrixVente}" Width="100"/>
                <DataGridTextColumn Header="Date Expiration" Binding="{Binding DateExpiration, StringFormat=d}" Width="130"/>
            </DataGrid.Columns>
        </DataGrid>

        <TextBlock Grid.Row="3" Text="" x:Name="txtStatus" Foreground="Gray" Margin="0,8,0,0" />
    </Grid>
</Page>
