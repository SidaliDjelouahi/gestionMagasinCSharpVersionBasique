<Window x:Class="MonAppGestion.EditLastLineWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="Modifier la dernière ligne" Height="180" Width="360" WindowStartupLocation="CenterOwner" ResizeMode="NoResize"
    Loaded="Window_Loaded">
    <Grid Margin="8">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <TextBlock Grid.Row="0" Grid.Column="0" Text="Produit:" VerticalAlignment="Center" Margin="0,4" />
        <TextBox x:Name="txtName" Grid.Row="0" Grid.Column="1" Margin="8,4" IsReadOnly="True" />

        <TextBlock Grid.Row="1" Grid.Column="0" Text="Quantité:" VerticalAlignment="Center" Margin="0,4" />
        <TextBox x:Name="txtQty" Grid.Row="1" Grid.Column="1" Margin="8,4" />

        <TextBlock Grid.Row="2" Grid.Column="0" Text="Prix vente:" VerticalAlignment="Center" Margin="0,4" />
        <TextBox x:Name="txtPrice" Grid.Row="2" Grid.Column="1" Margin="8,4" />

        <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button x:Name="btnOk" Content="OK" Width="80" Margin="4,0" Click="btnOk_Click" />
            <Button Content="Annuler" Width="80" Margin="4,0" Click="btnCancel_Click" />
        </StackPanel>
    </Grid>
</Window>