<Page x:Class="MonAppGestion.BonDeVenteConsulter"
      xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
      xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
      Title="Consulter Bon de Vente"
      Loaded="Page_Loaded">
    <Grid Margin="12">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Grid.Row="0" VerticalAlignment="Center">
            <TextBlock Text="Numéro : " FontWeight="Bold" />
            <TextBlock x:Name="txtNumVente" Margin="6,0" />
            <TextBlock Text="Date : " FontWeight="Bold" Margin="20,0,0,0" />
            <TextBlock x:Name="txtDateVente" Margin="6,0" />
        </StackPanel>

        <StackPanel Orientation="Horizontal" Grid.Row="1" Margin="0,8,0,8">
            <Button Content="Retour" Click="btnBack_Click" Width="100" />
            <Button x:Name="btnDeleteVente" Content="Supprimer le bon" Click="btnDeleteVente_Click" Width="160" Margin="8,0,0,0" />
        </StackPanel>

        <DataGrid x:Name="dgVenteDetails" Grid.Row="2" AutoGenerateColumns="False" CanUserAddRows="False">
            <DataGrid.Columns>
                <DataGridTextColumn Header="Produit" Binding="{Binding Nom}" Width="*" />
                <DataGridTextColumn Header="Prix" Binding="{Binding PrixVente}" Width="120" />
                <DataGridTextColumn Header="Qte" Binding="{Binding Qte}" Width="80" />
                <DataGridTextColumn Header="Total" Binding="{Binding Total}" Width="120" />
                    <DataGridTemplateColumn Header="Actions" Width="140">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="Supprimer" Click="Action_DeleteDetail_Click" Margin="4,0" />
                                </StackPanel>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</Page>
